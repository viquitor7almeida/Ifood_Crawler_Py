# iFood Crawler Configuration
# Copy to .env and customize

LOG_LEVEL=INFO

# Crawler settings
CRAWLER_PARALLELISM=5
CRAWLER_MAX_RETRIES=5

# Flaresolverr
CRAWLER_FLARESOLVERR_URL=http://flaresolverr:8191
CRAWLER_FLARESOLVERR_TIMEOUT=180

# Input / Output
CRAWLER_INPUT_FILE=/app/data/ifood_urls_padrao_item_1000.csv
CRAWLER_OUTPUT_DIR=/app/output

# Checkpoint
CRAWLER_CHECKPOINT_DB_PATH=/app/checkpoints/checkpoint.db

# Cookies
CRAWLER_COOKIE_STORE_PATH=/app/cookies/cookies.json
